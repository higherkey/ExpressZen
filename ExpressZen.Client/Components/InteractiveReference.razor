<div class="row" style="margin-top: 4rem;">
    <div class="column">
        <h3>Interactive Reference (Cheat Sheet)</h3>
        <p>A quick-glance guide to common Regular Expression tokens for .NET.</p>

        <div class="row">
            <div class="column">
                <h5 style="color: #bb86fc;">Anchors</h5>
                <ul style="list-style-type: none; padding: 0; font-size: 1.1rem;">
                    <li><code class="token-bg">^</code> Start of string or line</li>
                    <li><code class="token-bg">$</code> End of string or line</li>
                    <li><code class="token-bg">\b</code> Word boundary</li>
                    <li><code class="token-bg">\B</code> Non-word boundary</li>
                </ul>
            </div>
            
            <div class="column">
                <h5 style="color: #bb86fc;">Character Classes</h5>
                <ul style="list-style-type: none; padding: 0; font-size: 1.1rem;">
                    <li><code class="token-bg">.</code> Any character except newline</li>
                    <li><code class="token-bg">\w</code> Word character</li>
                    <li><code class="token-bg">\d</code> Digit (0-9)</li>
                    <li><code class="token-bg">\s</code> Whitespace</li>
                </ul>
            </div>

            <div class="column">
                <h5 style="color: #bb86fc;">Quantifiers</h5>
                <ul style="list-style-type: none; padding: 0; font-size: 1.1rem;">
                    <li><code class="token-bg">*</code> 0 or more</li>
                    <li><code class="token-bg">+</code> 1 or more</li>
                    <li><code class="token-bg">?</code> 0 or 1</li>
                    <li><code class="token-bg">{3}</code> Exactly 3</li>
                    <li><code class="token-bg">{3,}</code> 3 or more</li>
                </ul>
            </div>
            
            <div class="column">
                <h5 style="color: #bb86fc;">Groups</h5>
                <ul style="list-style-type: none; padding: 0; font-size: 1.1rem;">
                    <li><code class="token-bg">(abc)</code> Capture group</li>
                    <li><code class="token-bg">(?:abc)</code> Non-capturing group</li>
                    <li><code class="token-bg">[abc]</code> Any of a, b, or c</li>
                    <li><code class="token-bg">[^abc]</code> Not a, b, or c</li>
                </ul>
            </div>
        </div>
    </div>
</div>

