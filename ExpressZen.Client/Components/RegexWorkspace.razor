@using ExpressZen.Client.Models
@using ExpressZen.Client.Services
@inject IRegexEngine Engine
@inject IAiAssistantService AiService

<div class="row" style="max-width: 100%;">
    <!-- Main Workspace Column (70%) -->
    <div class="column column-70" style="display: flex; flex-direction: column; gap: 1rem;">
        
        <!-- Big Regex Input with Options Dropdown -->
        <div style="background-color: #1e1e1e; border: 1px solid #333; border-radius: 4px; padding: 1rem;">
            <div style="font-size: 0.75rem; text-transform: uppercase; color: #888; font-weight: bold; margin-bottom: 0.5rem;">Regular Expression</div>
            <div style="display: flex; align-items: center; background: #121212; border: 1px solid #444; border-radius: 4px; padding: 0.5rem 1rem;">
                <span style="color: #666; font-size: 1.5rem; padding-right: 0.5rem; user-select: none;">/</span>
                <input type="text" id="patternInput" value="@Pattern" @oninput="OnPatternInputAsync" style="width: 100%; background: transparent; border: none; font-family: monospace; font-size: 2.0rem; color: #bb86fc; outline: none; margin: 0; padding: 0;" spellcheck="false" />
                <span style="color: #666; font-size: 1.5rem; padding-left: 0.5rem; user-select: none;">/</span>
                <select style="margin: 0; margin-left: 0.5rem; background-color: #1e1e1e; color: #bb86fc; border: 1px solid #444; border-radius: 4px; font-size: 1.1rem; width: auto; font-family: monospace; padding: 0.3rem 2.5rem 0.3rem 0.8rem; cursor: pointer; outline: none; appearance: auto;">
                    <option value="gm">gm</option>
                    <option value="g">g</option>
                    <option value="i">i</option>
                    <option value="gi">gi</option>
                    <option value="m">m</option>
                    <option value="gim">gim</option>
                </select>
            </div>
            @if (!string.IsNullOrEmpty(GlobalError))
            {
                <div style="color: #ff8080; margin-top: 0.5rem; font-size: 0.9rem;">
                    <strong>Execution Error:</strong> @GlobalError
                </div>
            }
        </div>

        <!-- Master Test Strings Section -->
        <div style="background-color: #1e1e1e; border: 1px solid #333; border-radius: 4px; padding: 1rem; display: flex; flex-direction: column; flex: 1;">
            
            <!-- Toolbar for Views -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px solid #333; padding-bottom: 0.5rem;">
                <div style="font-size: 0.75rem; text-transform: uppercase; color: #888; font-weight: bold;">Test Strings</div>
                <div style="display: flex; gap: 0.5rem;">
                    <button class="button @(CurrentView == ViewMode.ValidOnly ? "" : "button-clear")" style="@(CurrentView == ViewMode.ValidOnly ? "background-color: #333; border-color: #333;" : "color: #888;") margin: 0; padding: 0 1rem; height: 3rem; line-height: 3rem;" @onclick="() => CurrentView = ViewMode.ValidOnly">Matches</button>
                    <button class="button @(CurrentView == ViewMode.Split ? "" : "button-clear")" style="@(CurrentView == ViewMode.Split ? "background-color: #333; border-color: #333;" : "color: #888;") margin: 0; padding: 0 1rem; height: 3rem; line-height: 3rem;" @onclick="() => CurrentView = ViewMode.Split">Split</button>
                    <button class="button @(CurrentView == ViewMode.InvalidOnly ? "" : "button-clear")" style="@(CurrentView == ViewMode.InvalidOnly ? "background-color: #333; border-color: #333;" : "color: #888;") margin: 0; padding: 0 1rem; height: 3rem; line-height: 3rem;" @onclick="() => CurrentView = ViewMode.InvalidOnly">Non-Matches</button>
                </div>
            </div>

            <!-- Dual Panes Layout -->
            <div style="display: flex; gap: 1rem; flex: 1; align-items: stretch;">
                
                <!-- VALID PANE -->
                @if (CurrentView == ViewMode.ValidOnly || CurrentView == ViewMode.Split)
                {
                    <div style="flex: 1; display: flex; flex-direction: column;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <span style="color: #4CAF50; font-size: 0.9rem; font-weight: bold;">Should Match</span>
                            <div style="display: flex; gap: 0.5rem;">
                                <button class="button button-clear" style="padding: 0 0.5rem; margin: 0; height: auto; line-height: 1; font-size: 0.75rem; color: #bb86fc;" @onclick="() => FillLorem(ValidTestData)" title="Insert Lorem Ipsum">Lrm</button>
                                <button class="button button-clear" style="padding: 0 0.5rem; margin: 0; height: auto; line-height: 1; font-size: 0.75rem; color: #bb86fc;" @onclick="() => InferPrimaryMatches(true)" disabled="@IsInferringMatches" title="AI Generate">AI</button>
                                <button class="button button-clear" style="padding: 0 0.5rem; margin: 0; height: auto; line-height: 1; font-size: 0.75rem; color: #888;" @onclick="() => ValidTestData.Text = string.Empty" title="Clear">Clr</button>
                            </div>
                        </div>
                        <textarea @bind="ValidTestData.Text" @bind:event="oninput" placeholder="Valid test strings here..." style="width: 100%; min-height: 300px; flex: 1; background: #121212; border: 1px solid #444; border-radius: 4px; font-family: monospace; font-size: 1.3rem; color: #e0e0e0; outline: none; margin: 0; padding: 1rem; resize: vertical; @GetStyle(ValidTestData)" spellcheck="false"></textarea>
                    </div>
                }

                <!-- INVALID PANE -->
                @if (CurrentView == ViewMode.InvalidOnly || CurrentView == ViewMode.Split)
                {
                    <div style="flex: 1; display: flex; flex-direction: column;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <span style="color: #ff4d4d; font-size: 0.9rem; font-weight: bold;">Should NOT Match</span>
                            <div style="display: flex; gap: 0.5rem;">
                                <button class="button button-clear" style="padding: 0 0.5rem; margin: 0; height: auto; line-height: 1; font-size: 0.75rem; color: #bb86fc;" @onclick="() => FillLorem(InvalidTestData)" title="Insert Lorem Ipsum">Lrm</button>
                                <button class="button button-clear" style="padding: 0 0.5rem; margin: 0; height: auto; line-height: 1; font-size: 0.75rem; color: #bb86fc;" @onclick="() => InferPrimaryMatches(false)" disabled="@IsInferringNonMatches" title="AI Generate">AI</button>
                                <button class="button button-clear" style="padding: 0 0.5rem; margin: 0; height: auto; line-height: 1; font-size: 0.75rem; color: #888;" @onclick="() => InvalidTestData.Text = string.Empty" title="Clear">Clr</button>
                            </div>
                        </div>
                        <textarea @bind="InvalidTestData.Text" @bind:event="oninput" placeholder="Invalid test strings here..." style="width: 100%; min-height: 300px; flex: 1; background: #121212; border: 1px solid #444; border-radius: 4px; font-family: monospace; font-size: 1.3rem; color: #e0e0e0; outline: none; margin: 0; padding: 1rem; resize: vertical; @GetStyle(InvalidTestData)" spellcheck="false"></textarea>
                    </div>
                }
            </div>

            <!-- Minimalist Edge-Case Assertions -->
            <div style="margin-top: 2rem; border-top: 1px solid #333; padding-top: 1rem;">
                <div style="font-size: 0.75rem; text-transform: uppercase; color: #888; font-weight: bold; margin-bottom: 0.5rem;">Unit Test Assertions (Single Line)</div>
                <div class="row">
                    <div class="column">
                        @foreach (var item in MustMatchItems)
                        {
                            <div style="display: flex; margin-bottom: 0.2rem; align-items: center;">
                                <span style="color: #4CAF50; padding-right: 0.5rem; width: 1.5rem; text-align: center;">✓</span>
                                <input type="text" value="@item.Text" @oninput="(e) => UpdateMatchItem(item, e)" placeholder="Empty assertion..." style="font-family: monospace; margin-bottom: 0; flex: 1; border: none; border-bottom: 1px solid #333; background: transparent; padding: 0.5rem; border-radius: 0; font-size: 1.2rem; @GetStyle(item)" spellcheck="false" />
                            </div>
                        }
                    </div>
                    <div class="column">
                        @foreach (var item in MustNotMatchItems)
                        {
                            <div style="display: flex; margin-bottom: 0.2rem; align-items: center;">
                                <span style="color: #ff4d4d; padding-right: 0.5rem; width: 1.5rem; text-align: center;">✗</span>
                                <input type="text" value="@item.Text" @oninput="(e) => UpdateNonMatchItem(item, e)" placeholder="Empty assertion..." style="font-family: monospace; margin-bottom: 0; flex: 1; border: none; border-bottom: 1px solid #333; background: transparent; padding: 0.5rem; border-radius: 0; font-size: 1.2rem; @GetStyle(item)" spellcheck="false" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Escaping Hell & Tooling Sidebar (30%) -->
    <div class="column column-30" style="padding-left: 1rem;">
        <LiteralTranslator Pattern="@Pattern" />
    </div>
</div>

@code {
    [Parameter]
    public string Pattern { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> PatternChanged { get; set; }

    private enum ViewMode { Split, ValidOnly, InvalidOnly }
    private ViewMode CurrentView { get; set; } = ViewMode.Split;

    public async Task ForceEvaluateAsync() => await EvaluateAllAsync();

    private async Task OnPatternInputAsync(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        Pattern = val;
        await PatternChanged.InvokeAsync(val);
        await EvaluateAllAsync();
    }

    public string GlobalError { get; set; } = string.Empty;
    public TimeSpan ExecutionTime { get; set; } = TimeSpan.Zero;

    // Primary blocks
    private TestData ValidTestData = new() { ExpectedToMatch = true, Text = "test@example.com\nadmin@site.org" };
    private TestData InvalidTestData = new() { ExpectedToMatch = false, Text = "invalid-email\nnot.an.email" };

    // Minimalist single-line assertions
    private List<TestData> MustMatchItems = new() { new TestData { ExpectedToMatch = true } }; // Always one empty
    private List<TestData> MustNotMatchItems = new() { new TestData { ExpectedToMatch = false } }; // Always one empty

    private void UpdateMatchItem(TestData item, ChangeEventArgs e)
    {
        item.Text = e.Value?.ToString() ?? string.Empty;
        EnsureEmptyRow(MustMatchItems, true);
        _ = EvaluateAllAsync();
    }

    private void UpdateNonMatchItem(TestData item, ChangeEventArgs e)
    {
        item.Text = e.Value?.ToString() ?? string.Empty;
        EnsureEmptyRow(MustNotMatchItems, false);
        _ = EvaluateAllAsync();
    }

    private void EnsureEmptyRow(List<TestData> list, bool expected)
    {
        // Remove completely empty rows except the last one
        for (int i = list.Count - 2; i >= 0; i--)
        {
            if (string.IsNullOrWhiteSpace(list[i].Text)) list.RemoveAt(i);
        }
        // Always ensure last row is empty to act as "Add new"
        if (!string.IsNullOrWhiteSpace(list.LastOrDefault()?.Text))
        {
            list.Add(new TestData { ExpectedToMatch = expected });
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await EvaluateAllAsync();
        }
    }

    private async Task EvaluateAllAsync()
    {
        GlobalError = string.Empty;
        var totalTime = TimeSpan.Zero;

        var allItems = new[] { ValidTestData, InvalidTestData }.Concat(MustMatchItems).Concat(MustNotMatchItems);

        foreach (var item in allItems)
        {
            if (string.IsNullOrWhiteSpace(item.Text)) 
            {
                item.Result = null;
                continue;
            }

            var result = await Engine.EvaluateAsync(Pattern, item.Text);
            item.Result = result;
            
            if (!string.IsNullOrEmpty(result.ErrorMessage) && string.IsNullOrEmpty(GlobalError))
            {
                GlobalError = result.ErrorMessage;
            }

            totalTime += result.ExecutionTime;
        }

        ExecutionTime = totalTime;
        await InvokeAsync(StateHasChanged);
    }

    private string GetStyle(TestData item)
    {
        if (item.Result == null || string.IsNullOrWhiteSpace(Pattern) || string.IsNullOrWhiteSpace(item.Text)) 
            return "background-color: #121212;";

        if (item.Result.ErrorMessage != string.Empty)
            return "background-color: rgba(255, 77, 77, 0.1); border-color: #ff4d4d; color: #ff8080;";

        var passed = item.Result.IsMatch == item.ExpectedToMatch;
        return passed ? "background-color: rgba(76, 175, 80, 0.1); border-color: #4CAF50; color: #81c784;" : "background-color: rgba(255, 77, 77, 0.1); border-color: #ff4d4d; color: #ff8080;";
    }

    private void FillLorem(TestData target)
    {
        target.Text = "Lorem ipsum dolor sit amet, consectetur adipiscing elit.\nSed do eiusmod tempor incididunt ut labore et dolore magna aliqua.\nUt enim ad minim veniam, quis nostrud exercitation ullamco laboris.";
        _ = EvaluateAllAsync();
    }

    private bool IsInferringMatches = false;
    private bool IsInferringNonMatches = false;

    private async Task InferPrimaryMatches(bool valid)
    {
        if (string.IsNullOrWhiteSpace(Pattern)) return;
        
        if (valid) IsInferringMatches = true;
        else IsInferringNonMatches = true;
        
        var generated = await AiService.GenerateTestDataAsync(Pattern, valid);
        
        if (valid) ValidTestData.Text = string.Join("\n", generated);
        else InvalidTestData.Text = string.Join("\n", generated);
        
        await EvaluateAllAsync();
        
        if (valid) IsInferringMatches = false;
        else IsInferringNonMatches = false;
    }
}
