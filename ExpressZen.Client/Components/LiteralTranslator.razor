<div style="background-color: #1e1e1e; border: 1px solid #333; border-radius: 4px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
    <div style="border-bottom: 1px solid #333; padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
        <h4 style="color: #bb86fc; font-weight: bold; margin: 0; font-size: 1.2rem;">"Escaping Hell" Translator</h4>
        <p style="color: #888; font-size: 0.85rem; margin: 0; margin-top: 0.5rem;">Formats your regex for use as C# string literals.</p>
    </div>

    <!-- Generated Strings -->
    <div>
        <label style="color: #ccc; font-size: 0.8rem; text-transform: uppercase;">C# Verbatim String (<strong>@@"..."</strong>)</label>
        <div style="background-color: #121212; border: 1px solid #444; border-radius: 4px; padding: 0.5rem 1rem; overflow-x: auto;">
            <code style="color: #e0e0e0; font-family: monospace; white-space: pre;"><span style="color: #569cd6;">string</span> pattern = <span style="color: #ce9178;">@@"@EscapeVerbatim(Pattern)"</span>;</code>
        </div>
    </div>

    <div style="margin-top: 0.5rem;">
        <label style="color: #ccc; font-size: 0.8rem; text-transform: uppercase;">C# Regular String (<strong>"..."</strong>)</label>
        <div style="background-color: #121212; border: 1px solid #444; border-radius: 4px; padding: 0.5rem 1rem; overflow-x: auto;">
            <code style="color: #e0e0e0; font-family: monospace; white-space: pre;"><span style="color: #569cd6;">string</span> pattern = <span style="color: #ce9178;">"@EscapeRegular(Pattern)"</span>;</code>
        </div>
    </div>

    <div style="margin-top: 0.5rem;">
        <label style="color: #ccc; font-size: 0.8rem; text-transform: uppercase;">C# 11+ Raw String (<strong>"""..."""</strong>)</label>
        <div style="background-color: #121212; border: 1px solid #444; border-radius: 4px; padding: 0.5rem 1rem; overflow-x: auto;">
            <code style="color: #e0e0e0; font-family: monospace; white-space: pre;"><span style="color: #569cd6;">string</span> pattern = <span style="color: #ce9178;">"""@Pattern"""</span>;</code>
        </div>
    </div>

    <!-- Usage Example -->
    <div style="margin-top: 1.5rem; border-top: 1px solid #333; padding-top: 1rem;">
        <label style="color: #bbb; font-size: 0.85rem; text-transform: uppercase; font-weight: bold; margin-bottom: 0.5rem; display: block;">Usage Example (.NET 8)</label>
        <div style="background-color: #121212; border: 1px solid #444; border-radius: 4px; padding: 1rem; overflow-x: auto;">
<pre style="margin: 0; padding: 0; background: transparent; border: none; font-family: monospace; font-size: 0.85rem; color: #d4d4d4;"><span style="color: #c586c0;">using</span> System.Text.RegularExpressions;

<span style="color: #6a9955;">// 1. Define Pattern</span>
<span style="color: #569cd6;">string</span> pattern = <span style="color: #ce9178;">@@"@EscapeVerbatim(Pattern)"</span>;

<span style="color: #6a9955;">// 2. Safe Execution (ReDoS protection)</span>
<span style="color: #4ec9b0;">TimeSpan</span> timeout = <span style="color: #4ec9b0;">TimeSpan</span>.FromMilliseconds(500);

<span style="color: #569cd6;">bool</span> isMatch = <span style="color: #4ec9b0;">Regex</span>.IsMatch(input, pattern, 
    <span style="color: #4ec9b0;">RegexOptions</span>.None, timeout);
</pre>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Pattern { get; set; } = string.Empty;

    private string EscapeVerbatim(string input)
    {
        if (string.IsNullOrEmpty(input)) return string.Empty;
        // Verbatim strings only need double quotes escaped
        return input.Replace("\"", "\"\"");
    }

    private string EscapeRegular(string input)
    {
        if (string.IsNullOrEmpty(input)) return string.Empty;
        // Regular strings literally need EVERYTHING escaped (the absolute hell)
        return input.Replace("\\", "\\\\").Replace("\"", "\\\"");
    }
}
